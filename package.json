{
  "name": "xhs-redbook-research-system",
  "productName": "小红书运营台",
  "description": "面向公司内部业务员的本地小红书研究与内容运营桌面工具",
  "author": "Internal Operations Team",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "dist/server/electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.server.json && vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "start": "node dist/server/server/index.js",
    "desktop:start": "npm run build && electron .",
    "desktop:package": "npm run build && electron-forge package --platform=win32 --arch=x64",
    "desktop:make": "npm run build && electron-forge make --platform=win32 --arch=x64"
  },
  "dependencies": {
    "@lucasygu/redbook": "^0.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "electron-squirrel-startup": "^1.0.1",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^43.1.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.15"
  }
}
